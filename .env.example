# ═══════════════════════════════════════════════════════════════════════════
# APEX — copy to .env (agents, Hardhat) and .env.local (Vite — VITE_* only)
# Never commit real keys. Service role / private keys = server-side only.
# ═══════════════════════════════════════════════════════════════════════════

# ── HashKey Chain testnet ───────────────────────────────────────────────────
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz
PRIVATE_KEY=
APEX_AGENT_ADDRESS=
SEED_VAULT=1

# After `npx hardhat run scripts/deploy.cjs --network hashkeyTestnet`
VAULT_CONTRACT=
DECISION_LOG_CONTRACT=
AGENT_REGISTRY_CONTRACT=
IDENTITY_REGISTRY_CONTRACT=
SETTLEMENT_ROUTER_CONTRACT=
MOCK_SILVER=
MOCK_MMF=
MOCK_SEC=
MOCK_USDC=
FAUCET_SILVER=
FAUCET_MMF=
FAUCET_SEC=
FAUCET_USDC=

# ── OpenAI (Decision Agent — validated JSON + Zod) ─────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MIN_INTERVAL_SEC=30
OPENAI_MAX_CALLS_PER_HOUR=180

# ── Monitor / Pipeline ─────────────────────────────────────────────────────
MONITOR_INTERVAL_SEC=60
MONITOR_ALERT_MIN_INTERVAL_SEC=300
LOG_LEVEL=info
USE_ORACLE_PRICING=0
TOKEN_PRICE_FEEDS_JSON=
ORACLE_MAX_STALENESS_SEC=21600
DECISION_MODE=hybrid

# Auto-execute on-chain after REBALANCE_NEEDED (requires agent wallet + OpenAI + decision log)
PIPELINE_AUTO_EXECUTE=0
MIN_DECISION_CONFIDENCE=72
MIN_SECONDS_BETWEEN_EXECUTIONS=600
MAX_REBALANCE_PCT_OF_BALANCE=25

# ── Supabase (run agent/supabase.sql) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional CLI vars for linking per-vault Telegram channels (multi-tenant):
# LINK_PORTFOLIO_ID=0xVaultAddress
# LINK_TELEGRAM_CHAT_ID=6689707513
# LINK_USER_ID=<supabase-user-id>

# ── HSP (optional future adapter) ───────────────────────────────────────────
HSP_BASE_URL=https://merchant-qa.hashkeymerchant.com
HSP_API_KEY=
HSP_MERCHANT_ID=
HSP_CREATE_PAYMENT_PATH=/api/payments
# JSON body for `npm run agent:settlement` (merchant-specific fields)
# HSP_PAYMENT_BODY_JSON={"amount":"100","currency":"USD"}

# ── NexaID (optional future adapter) ────────────────────────────────────────
NEXAID_TEMPLATE_ID=
NEXAID_VERIFY_BASE_URL=

# ── Manual execution (optional) ─────────────────────────────────────────────
# EXEC_ASSET=0x...
# EXEC_DIRECTION=reduce
# EXEC_AMOUNT=1000000000000000000
# EXEC_CONFIDENCE=85
# EXEC_REASONING=manual-rebalance
# EXEC_DRY_RUN=1

# ── Vite frontend (.env.local) ─────────────────────────────────────────────
# VITE_PUBLIC_RPC_URL=https://testnet.hsk.xyz
# VITE_PUBLIC_VAULT_ADDRESS=0x...
# VITE_WALLETCONNECT_PROJECT_ID=
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_PUBLIC_USDC_FAUCET_URL=https://faucet.circle.com/

# Runs monitor/pipeline in a container. Pass env at runtime (Kubernetes secrets, docker --env-file).
# Uses full `npm install` so Hardhat-era devDependencies (ethers, openai, etc.) are available to agents.
FROM node:22-bookworm-slim

WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --ignore-scripts

COPY agent ./agent
COPY contracts ./contracts

ENV NODE_ENV=production
CMD ["node", "agent/pipeline.mjs"]
